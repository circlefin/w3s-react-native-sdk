{
  "name": "@circle-fin/w3s-pw-react-native-sdk",
  "version": "2.0.2",
  "packageManager": "yarn@1.22.22",
  "description": "React Native SDK for Circle Programmable Wallet",
  "main": "build/index.js",
  "source": "src/index.ts",
  "types": "build/index.d.ts",
  "files": [
    "build",
    "android/src",
    "android/build.gradle",
    "ios",
    "plugins",
    "src",
    "expo-module.config.json",
    "app.json",
    "README.md",
    "BARE_REACT_NATIVE_GUIDE.md",
    "!**/__test__",
    "!**/__tests__",
    "!**/__mocks__",
    "!**/*.test.ts",
    "!**/*.test.tsx",
    "!android/build/",
    "!android/.gradle/",
    "!**/*.class"
  ],
  "scripts": {
    "build": "expo-module build",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "test": "expo-module test",
    "test:ci": "jest --ci --watchAll=false --runInBand --passWithNoTests",
    "prepare": "expo-module prepare",
    "prepublishOnly": "expo-module prepublishOnly",
    "expo-module": "expo-module",
    "open:ios": "xed example/ios",
    "open:android": "open -a \"Android Studio\" example/android",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint:raw": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:type": "tsc --noEmit",
    "publish:sdk": "npm publish --registry https://npm.pkg.github.com/",
    "test:with-copy-files": "npm --prefix ./example run verify:with-copy-files"
  },
  "keywords": [
    "react-native",
    "expo",
    "@circle-fin/w3s-pw-react-native-sdk",
    "circle",
    "circle.com",
    "usdc",
    "euroc",
    "stablecoins",
    "programmable wallets",
    "rn",
    "ios",
    "android"
  ],
  "repository": "https://github.com/circlefin/w3s-react-native-sdk.git",
  "bugs": {
    "url": "https://github.com/circlefin/w3s-react-native-sdk.git/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "author": "Circle Internet Financial, LTD.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/circlefin/w3s-react-native-sdk.git #readme",
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@expo/config-plugins": "~10.1.2",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-native": "^5.0.0",
    "expo": "~53.0.12",
    "expo-module-scripts": "^4.1.6",
    "expo-modules-core": "~2.4.2",
    "jest": "^29.7.0",
    "prettier": "^3.6.2",
    "react": "^19.2.0",
    "react-native": "0.79.3",
    "react-test-renderer": "^19.2.0",
    "ts-jest": "^29.4.5",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "expo": "*",
    "expo-modules-core": "*",
    "react": "*",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "expo": {
      "optional": true
    }
  }
}
